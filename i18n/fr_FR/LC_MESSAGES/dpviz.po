msgstr ""
"Affiche la liste des agents dynamiques actuellement affectés aux files "
"d'attente."

msgid "Show Ring Group Members"
msgstr "Montrer les membres du groupe d'appel"

msgid ""
"\"Single\" displays individual member nodes. \"Combine\" displays all members "
"in a single node. \"Hide\" does not display members."
msgstr ""
"\"Single\" affiche les nœuds individuels. \"Combine\" affiche tous les "
"membres dans un seul nœud. \"Hide\" ne désplaye pas les membres."

