#: /var/www/html/admin/modules/dpviz/views/options.php:204
msgid "Inbound Routes will show the destination."
msgstr "Входящие маршруты покажут направление."

#: /var/www/html/admin/modules/dpviz/views/options.php:216
msgid "Display Insert and Add Selection Nodes"
msgstr "Отображение узлов \"Вставка\" и \"Добавление выбора\""

#: /var/www/html/admin/modules/dpviz/views/options.php:231
msgid ""
"Displays a + between nodes. Clicking it creates a new destination and "
"automatically links it to the current destination. Also Displays Add "
"Selection (IVRs) and Add Entry (Dynamic Routes) "
msgstr ""
"Отображает знак + между узлами. Нажатие на него создает новую цель и "
"автоматически связывает ее с текущей целью. Также отображает добавление "
"выбора (IVR) и добавление записи (Динамические маршруты) "

#: /var/www/html/admin/modules/dpviz/views/options.php:243
msgid "Display In Use By Nodes"
msgstr "Отображение В Употреблении У Узлов"

#: /var/www/html/admin/modules/dpviz/views/options.php:258
msgid "Display nodes where the selected destination is used."
msgstr "Отображать узлы, используемые в выбранном назначении."

#: /var/www/html/admin/modules/dpviz/views/options.php:270
msgid "Shared extension node handling"
msgstr "Общий узел обработки расширений"

#: /var/www/html/admin/modules/dpviz/views/options.php:278
msgid "Queues and Ring Groups Only"
msgstr "Очереди и группы звонков"

#: /var/www/html/admin/modules/dpviz/views/options.php:281
msgid "All Destinations"
msgstr "Все направления"

#: /var/www/html/admin/modules/dpviz/views/options.php:289
msgid ""
"\"None\" displays individual extension nodes. \"Queues and Ring Groups "
"Only\" combines them into one node. \"All\" merges all destinations into a "
"single extension node."
msgstr ""
"\"None\" отображает отдельные узлы расширений. \"Колея и Группы колеи "
"только\" объединяет их в один узел. \"Все\" объединяет все направления в "
"единый узел расширения."

#: /var/www/html/admin/modules/dpviz/views/options.php:303
msgid "Show Allowlist"
msgstr "Показать разрешённый список"

#: /var/www/html/admin/modules/dpviz/views/options.php:321
msgid "Displays the Allowlist information and destination."
msgstr "Отображает информацию о списке разрешений и назначении."

#: /var/www/html/admin/modules/dpviz/views/options.php:323
msgid "Allowlist module is not installed."
msgstr "Модуль Allowlist не установлен."

#: /var/www/html/admin/modules/dpviz/views/options.php:336
msgid "Show Blacklist"
msgstr "Показать черный список"

#: /var/www/html/admin/modules/dpviz/views/options.php:351
msgid "Displays the Blacklist information and destination."
msgstr "Отображает информацию о черном списке и назначении."

#: /var/www/html/admin/modules/dpviz/views/options.php:363
msgid "Show Queue Agents"
msgstr "Отобразить Очередь Агентов"

#: /var/www/html/admin/modules/dpviz/views/options.php:368
#: /var/www/html/admin/modules/dpviz/views/options.php:453
msgid "Single"
msgstr "Одиночный"

#: /var/www/html/admin/modules/dpviz/views/options.php:371
#: /var/www/html/admin/modules/dpviz/views/options.php:456
msgid "Combine"
msgstr "Соединить"

#: /var/www/html/admin/modules/dpviz/views/options.php:374
#: /var/www/html/admin/modules/dpviz/views/options.php:459
msgid "Hide"
msgstr "Скрыть"

#: /var/www/html/admin/modules/dpviz/views/options.php:382
msgid ""
"\"Single\" displays individual agent nodes. \"Combine\" displays all agents "
"in a single node. \"Hide\" does not display queue agents."
msgstr ""
"\"Одиночный\" отображает индивидуальные узлы агентов. \"Объединить\" "
"отображает всех агентов в одном узле. \"Скрыть\" не отображает агентов "
"очереди."

#: /var/www/html/admin/modules/dpviz/views/options.php:394
msgid "Show Dynamic Members for Queues"
msgstr "Показать динамические участники очередей"

#: /var/www/html/admin/modules/dpviz/views/options.php:409
msgid "Displays the list of dynamic agents currently assigned to the queues."
msgstr ""
"Отображает список динамических агентов, которые в данный момент назначены на "
"очереди."

#: /var/www/html/admin/modules/dpviz/views/options.php:421
msgid "Show Queue Agent Penalties"
msgstr "Показать штрафы агента очереди"

#: /var/www/html/admin/modules/dpviz/views/options.php:436
msgid "Displays the penalty value for queue agents."
msgstr "Отображает значение штрафа для агентов очереди."

#: /var/www/html/admin/modules/dpviz/views/options.php:448
msgid "Show Ring Group Members"
msgstr "Показать участников группы звонков"

#: /var/www/html/admin/modules/dpviz/views/options.php:467
msgid ""
"\"Single\" displays individual member nodes. \"Combine\" displays all "
"members in a single node. \"Hide\" does not display members."
msgstr ""
"\"Одиночный\" отображает отдельные узлы членов. \"Скомбинировать\" "
"отображает всех членов в одном узле. \"Скрыть\" не отображает членов."

#: /var/www/html/admin/modules/dpviz/views/options.php:479
msgid "Show Find Me Follow Me for Extensions"
msgstr "Показать Find Me Follow Me для Расширений"

#: /var/www/html/admin/modules/dpviz/views/options.php:494
msgid "Displays Find Me Follow Me data for extensions."
msgstr ""
"Отображает информацию о настройках \"Найди меня, следуй за мной\" для "
"расширений."

#: /var/www/html/admin/modules/dpviz/views/options.php:506
msgid "Show Extension Optional Destinations"
msgstr "Отобразить Дополнительные Назначения Расширения (по умолчанию)"

#: /var/www/html/admin/modules/dpviz/views/options.php:521
msgid ""
"Displays and follows the optional destinations (No Answer, Busy, Not "
"Reachable) set for the extension in the Advanced tab."
msgstr ""
"Отображает и следует по опциональным направлениям (недоступен, занят, "
"отсутствует ответ) установленным для расширения в разделе "
"\"Предосторожности\"."

#: /var/www/html/admin/modules/dpviz/views/options.php:533
