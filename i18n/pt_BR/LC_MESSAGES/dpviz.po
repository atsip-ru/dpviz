msgstr "Mostrar Agentes na Fila"

msgid "Single"
msgstr "Único"

msgid "Combine"
msgstr "Combinar"

msgid "Hide"
msgstr "Ocultar"

msgid ""
"\"Single\" displays individual agent nodes. \"Combine\" displays all agents "
"in a single node. \"Hide\" does not display queue agents."
msgstr ""
"\"Um\" exibe nós individuais de agentes. \"Combinar\" exibe todos os agentes "
"em um único nó. \"Esconder\" não exibe os agentes de fila."

msgid "Show Dynamic Members for Queues"
msgstr "Exibir Membros Dinâmicos para Filas"

msgid "Displays the list of dynamic agents currently assigned to the queues."
msgstr "Exibe a lista de agentes dinâmicos atualmente atribuídos às filas."

msgid "Show Ring Group Members"
msgstr "Exibir Membros do Grupo de Chamada"

msgid ""
"\"Single\" displays individual member nodes. \"Combine\" displays all members "
"in a single node. \"Hide\" does not display members."
msgstr ""
"\"Único\" exibe nós de membros individuais. \"Combinar\" exibe todos os "
"membros em um único nó. \"Ocultar\" não exibe membros."

